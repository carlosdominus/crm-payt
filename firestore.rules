rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPartner(ownerId) {
      // 1. Domain Access
      // Check if the owner has enabled domain access for the user's domain
      // We store this in workspaceConfig for the owner
      let userDomain = request.auth.token.email.split('@')[1];
      let hasDomainAccess = isSignedIn() && exists(/databases/$(database)/documents/workspaceConfig/$(ownerId)) 
        && get(/databases/$(database)/documents/workspaceConfig/$(ownerId)).data.domainAccessEnabled == true
        && get(/databases/$(database)/documents/workspaceConfig/$(ownerId)).data.ownerDomain == userDomain;
        
      if (hasDomainAccess) { return true; }
      
      // 2. Manual Access (Legacy/Fallback via invites)
      // We check if there's an invite for this user
      // Since we don't have a direct composite ID, we have to rely on the client's query
      // but for 'get', we'd need to know the invite ID.
      // This is harder. For now, let's prioritize Domain Access as the user requested.
      return false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Core User Data (Accessible by Owner and Partners) ---
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId) || isPartner(userId);
    }

    // --- Workspace Management ---
    
    match /workspaceConfig/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /workspaceKeys/{key} {
      allow get: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == incoming().ownerUid;
      allow delete: if isSignedIn() && request.auth.uid == existing().ownerUid;
    }

    match /domainWorkspaces/{domain} {
      allow get: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == incoming().ownerUid;
      allow delete: if isSignedIn() && request.auth.uid == existing().ownerUid;
    }

    match /invites/{inviteId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.ownerUid || request.auth.token.email.lower() == resource.data.inviteeEmail.lower());
      allow create: if isSignedIn() && request.auth.uid == incoming().ownerUid;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.ownerUid;
    }
  }
}
