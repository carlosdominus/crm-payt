rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isWorkspaceMember(ownerId) {
      return isOwner(ownerId) || (isSignedIn() && 
        exists(/databases/$(database)/documents/workspace_links/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/workspace_links/$(request.auth.uid)).data.ownerUid == ownerId);
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Workspace Management ---
    match /workspace_codes/{ownerUid} {
      allow read: if isSignedIn();
      allow write: if isOwner(ownerUid);
    }

    match /workspace_links/{guestUid} {
      allow read: if isSignedIn() && (request.auth.uid == guestUid || resource.data.ownerUid == request.auth.uid);
      allow create: if isOwner(guestUid);
      allow update: if isOwner(guestUid) || (isSignedIn() && existing().ownerUid == request.auth.uid);
      allow delete: if isOwner(guestUid) || (isSignedIn() && existing().ownerUid == request.auth.uid);
    }

    // --- User Tags ---
    match /users/{userId}/tags/{clientKey} {
      allow get: if isWorkspaceMember(userId);
      allow list: if isWorkspaceMember(userId);
      allow create: if isWorkspaceMember(userId) 
        && isValidId(clientKey)
        && isValidUserTag(incoming())
        && incoming().clientKey == clientKey;
      allow update: if isWorkspaceMember(userId)
        && isValidUserTag(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['tag', 'updatedAt'])
        && incoming().clientKey == existing().clientKey;
      allow delete: if isWorkspaceMember(userId);

      function isValidUserTag(data) {
        return data.keys().hasAll(['clientKey', 'tag', 'updatedAt'])
          && data.keys().size() == 3
          && data.clientKey is string && data.clientKey.size() <= 128
          && data.tag in ['pendente', 'vendido', 'lixo']
          && data.updatedAt is string;
      }
    }

    // --- Manual Sales ---
    match /users/{userId}/sales/{saleId} {
      allow get: if isWorkspaceMember(userId);
      allow list: if isWorkspaceMember(userId);
      allow create: if isWorkspaceMember(userId)
        && isValidId(saleId)
        && isValidManualSale(incoming())
        && incoming().id == saleId;
      allow update: if isWorkspaceMember(userId)
        && isValidManualSale(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['productName', 'value', 'commission', 'date', 'timestamp'])
        && incoming().id == existing().id
        && incoming().clientKey == existing().clientKey;
      allow delete: if isWorkspaceMember(userId);

      function isValidManualSale(data) {
        return data.keys().hasAll(['id', 'clientKey', 'productName', 'value', 'commission', 'date', 'timestamp'])
          && (data.keys().size() == 7 || (data.keys().size() == 8 && data.keys().hasAll(['createdAt'])))
          && data.id is string && data.id.size() <= 128
          && data.clientKey is string && data.clientKey.size() <= 128
          && data.productName is string && data.productName.size() <= 200
          && data.value is number && data.value >= 0
          && data.commission is number && data.commission >= 0
          && data.date is string
          && data.timestamp is number;
      }
    }

    // --- WhatsApp Accounts ---
    match /users/{userId}/whatsappAccounts/{accId} {
      allow get: if isWorkspaceMember(userId);
      allow list: if isWorkspaceMember(userId);
      allow create: if isWorkspaceMember(userId)
        && isValidId(accId)
        && isValidWhatsAppAccount(incoming())
        && incoming().id == accId;
      allow update: if isWorkspaceMember(userId)
        && isValidWhatsAppAccount(incoming())
        && incoming().id == existing().id;
      allow delete: if isWorkspaceMember(userId);

      function isValidWhatsAppAccount(data) {
        return data.keys().hasAll(['id', 'name', 'phoneNumber', 'identifier', 'color', 'createdAt'])
          && (data.keys().size() == 6 || data.keys().hasAll(['origin']))
          && data.id is string && data.id.size() <= 128
          && data.name is string && data.name.size() <= 100
          && data.phoneNumber is string && data.phoneNumber.size() <= 30
          && data.identifier is string && data.identifier.size() <= 20
          && data.color is string && data.color.size() <= 20
          && data.createdAt is string;
      }
    }

    // --- Client Extra Data ---
    match /users/{userId}/clientData/{clientKey} {
      allow get: if isWorkspaceMember(userId);
      allow list: if isWorkspaceMember(userId);
      allow create, update: if isWorkspaceMember(userId)
        && isValidId(clientKey)
        && isValidClientData(incoming())
        && incoming().clientKey == clientKey;
      allow delete: if isWorkspaceMember(userId);

      function isValidClientData(data) {
        return data.keys().hasAll(['clientKey', 'updatedAt'])
          && data.clientKey is string && data.clientKey.size() <= 128
          && (data.keys().size() <= 5)
          && (!data.keys().hasAll(['trackingCode']) || data.trackingCode is string)
          && (!data.keys().hasAll(['assignedWhatsappId']) || data.assignedWhatsappId is string);
      }
    }
  }
}
